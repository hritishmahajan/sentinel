# Copy to .env and fill in. Never commit .env to git.

ENVIRONMENT=dev
LOG_FORMAT=console
LOG_LEVEL=INFO

# Database (the docker-compose Postgres uses these credentials)
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
REDIS_URL=redis://localhost:6379/0

# Provider keys — at least one is required for the gateway to serve requests
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
XAI_API_KEY=xai-...          # Grok (xAI) — $25 free/month at console.x.ai

# Set to true in production to reject unauthenticated requests
REQUIRE_AUTH=false
